# ─────────────────────────────────────────────────────────────────────────────
# Zytek Solutions — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in values    (never commit .env to version control)
# 3. Add .env to .gitignore if not already present

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ── CORS (API server only) ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Do NOT add a trailing slash. Do NOT use wildcards (*) in production.
CORS_ORIGIN=https://zyteksolutions.com,https://www.zyteksolutions.com

# ── Site URL ──────────────────────────────────────────────────────────────────
# Used for canonical URLs, sitemaps, and OG tags
SITE_URL=https://zyteksolutions.com

# ── Contact form / Email ──────────────────────────────────────────────────────
# The API server sends contact form submissions to CONTACT_EMAIL via SMTP.
#
# Gmail (recommended — free):
#   1. Enable 2-Step Verification on your Google account
#   2. Go to myaccount.google.com → Security → App Passwords
#   3. Create an App Password for "Mail" and paste it as SMTP_PASS
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=zyteksolution@gmail.com
SMTP_PASS=your_gmail_app_password_here
CONTACT_EMAIL=zyteksolution@gmail.com
#
# Other providers:
#   Outlook/Hotmail: SMTP_HOST=smtp-mail.outlook.com  SMTP_PORT=587
#   Yahoo Mail:      SMTP_HOST=smtp.mail.yahoo.com     SMTP_PORT=587
#   Custom hosting:  Set SMTP_HOST to your host's SMTP server

# ── Analytics (if added) ──────────────────────────────────────────────────────
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── CAPTCHA (recommended when contact form is added) ─────────────────────────
# Cloudflare Turnstile (preferred — privacy-preserving alternative to reCAPTCHA)
# TURNSTILE_SECRET_KEY=your_cloudflare_turnstile_secret_key
# TURNSTILE_SITE_KEY=your_cloudflare_turnstile_site_key   (frontend, non-secret)

# ── WhatsApp Business API (if backend integration is added) ──────────────────
# WHATSAPP_PHONE=+923001234567
# WHATSAPP_API_TOKEN=your_token_here
